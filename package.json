{
  "name": "git-commit-suggester",
  "displayName": "Git Commit Suggester",
  "version": "0.0.2",
  "engines": {
    "vscode": "^1.80.0"
  },
  "main": "./src/extension.js",
  "activationEvents": [
    "*"
  ],
  "contributes": {
    "commands": [
      {
        "command": "gitcommit.suggest",
        "title": "Git: Suggest Commit Message"
      },
      {
        "command": "gitcommit.updateKey",
        "title": "Git: Update Gemini API Key"
      },
      {
        "command": "gitcommit.deleteKey",
        "title": "Git: Delete Gemini API Key"
      }
    ]
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0"
  }
}
